{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileUploadSettings": {
    "BasePath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".xls", ".xlsx" ]
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 300
  },
  "FileStorage": {
    "StorageProvider": "FileSystem",
    "ChunkSizeInMB": 10,
    "MaxFileSizeInGB": 2,
    "TempDirectory": "temp-uploads",
    "UploadDirectory": "uploads",
    "AllowedExtensions": [],
    "SessionExpirationHours": 24,
    "MaxConcurrentAssemblies": 5,
    "AssemblyTimeoutMinutes": 10
  },
  "AzureBlob": {
    "ConnectionString": "",
    "ContainerName": "qualitative-benchmarking-uploads"
  },
  "AwsS3": {
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "uploads",
    "Region": "us-east-1",
    "ServiceUrl": ""
  }
}
